# Kalshi API credentials
# KALSHI_API_KEY_ID    : Key ID string from Kalshi dashboard (Settings → API → Create Key)
# KALSHI_PRIVATE_KEY_PATH : path to the RSA private key .pem you generated (see README)
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=/Users/you/.kalshi/private_key.pem
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2

# Pipeline settings
EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25
MAX_BET_PCT=0.02

# Storage
DB_PATH=data/nba_reb.db
