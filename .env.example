# Kalshi API credentials
# KALSHI_API_KEY_ID       : Key ID from Kalshi dashboard (Settings → API → Create Key)
# KALSHI_PRIVATE_KEY_PATH : Path to RSA private key .pem (see setup_kalshi_key.py / README)
KALSHI_API_KEY_ID=your_key_id_here
KALSHI_PRIVATE_KEY_PATH=/Users/you/.kalshi/private_key.pem
# Demo vs live — match the host to the account you are using
KALSHI_BASE_URL=https://demo-api.kalshi.co/trade-api/v2
KALSHI_ORDER_URL=https://demo-api.kalshi.co/trade-api/v2

# Edge detection & sizing (config.py)
EDGE_THRESHOLD=0.05
KELLY_FRACTION=0.25
MAX_BET_PCT=0.02

# Tail-risk filters (config.py — used by edge_detector / scan)
MIN_P=0.12
TAIL_P_CUTOFF=0.20
TAIL_EDGE_MULT=1.5

# Storage
DB_PATH=data/nba_reb.db
